{
  "name": "metis",
  "version": "0.1.0",
  "description": "Metis, the open-source workflow engine: Temporal-backed, SQLite by default, with a node-graph editor and CLI.",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mindlynx-ai/metis.git"
  },
  "homepage": "https://github.com/mindlynx-ai/metis#readme",
  "bugs": "https://github.com/mindlynx-ai/metis/issues",
  "engines": {
    "node": ">=22.12"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit && npm run typecheck --workspaces --if-present",
    "lint": "eslint . && node scripts/check-style.mjs",
    "check:headers": "node scripts/check-headers.mjs",
    "test": "vitest run",
    "test:system": "vitest run --config vitest.system.config.ts",
    "test:cli-e2e": "vitest run packages/metis-cli/src/__tests__/up-run.e2e.spec.ts packages/metis-cli/src/__tests__/up-server.e2e.spec.ts packages/metis-cli/src/__tests__/real-nodes.e2e.spec.ts packages/metis-cli/src/temporal/__tests__/boot.e2e.spec.ts",
    "gates": "node gates/run-gates.mjs",
    "build": "node scripts/build-edition.mjs",
    "e2e": "playwright test",
    "e2e:full": "playwright test --config playwright.full.config.ts",
    "release-audit": "node scripts/release-audit.mjs",
    "check:publish": "node scripts/check-publish-freshness.mjs",
    "release:dry": "node scripts/publish-all.mjs",
    "release": "node scripts/publish-all.mjs --publish"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^2.0.0",
    "@playwright/test": "^1.58.0"
  }
}
