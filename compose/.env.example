# Copy to .env and fill in before running the production overlay:
#
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# Metis refuses to boot in production unless METIS_ADMIN_SECRET is set to a
# non-default value, so a public demo can never sit behind the default password.

# Admin login (userId: admin). Use a long random string.
METIS_ADMIN_SECRET=change-me-to-a-long-random-secret

# The hostname the demo is served on. Caddy gets a real TLS cert for it.
# With no domain, an sslip.io host resolves to your box's IP automatically,
# e.g. for an Elastic IP 203.0.113.10 use metis.203-0-113-10.sslip.io
METIS_DEMO_HOST=metis.<dashed-ip>.sslip.io

# Optional extra login for a tester (leave blank to skip). Editor by default.
METIS_DEMO_USER=lisa
METIS_DEMO_SECRET=change-me-too
METIS_DEMO_ROLE=editor
